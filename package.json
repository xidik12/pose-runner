{
  "name": "pose-runner-monorepo",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently -n broker,controller,tv -c green,blue,magenta \"pnpm --filter broker dev\" \"pnpm --filter controller dev\" \"pnpm --filter tv dev\"",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "certs": "bash scripts/make-certs.sh"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^20.16.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}