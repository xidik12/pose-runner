{
  "_comment": "Stance definitions for stance gate detector. Angles in radians (π = ~3.14159). Match StanceDefinition type in shared/src/index.ts. The thresholds favor accessibility — too strict and casual players bounce; too loose and the gate feels meaningless. Tune in playtests, not in code.",

  "_anglesGuide": {
    "leftElbow":     "shoulder-elbow-wrist (π ≈ straight arm, π/2 ≈ 90° bend)",
    "rightElbow":    "shoulder-elbow-wrist",
    "leftShoulder":  "hip-shoulder-elbow (π ≈ arm down, π/2 ≈ arm horizontal, near 0 ≈ arm up)",
    "rightShoulder": "hip-shoulder-elbow",
    "leftKnee":      "hip-knee-ankle (π ≈ straight leg, π/2 ≈ deep squat)",
    "rightKnee":     "hip-knee-ankle",
    "leftHip":       "shoulder-hip-knee (π ≈ standing, π/2 ≈ leg lifted forward)",
    "rightHip":      "shoulder-hip-knee",
    "torsoLean":     "shoulder-mid to hip-mid vs vertical, signed (positive = leaning right)"
  },

